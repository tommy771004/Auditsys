# OPENROUTER_API_KEY: Required for OpenRouter AI API calls (fallback models)
# Generate one at: https://openrouter.ai/keys
# Make sure your account has credits if you plan to use paid models (e.g. gemini-1.5-flash)
OPENROUTER_API_KEY="sk-or-v1-..."

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: The connection string for Neon PostgreSQL database.
DATABASE_URL="postgresql://user:password@endpoint.neon.tech/dbname?sslmode=require"

# JWT_SECRET: Secret key for signing JSON Web Tokens.
JWT_SECRET="YOUR_JWT_SECRET_HERE"

# VITE_API_URL: Base URL of the backend for the Live Execution Engine.
# Leave empty to use the same origin (the Express server proxies Vite in dev).
VITE_API_URL=""

# VITE_PAGESPEED_API_KEY: Optional Google PageSpeed Insights API key.
# Without it the public endpoint still works but is rate-limited per IP.
# Used as the LAB fallback when CrUX has no field data for a target.
VITE_PAGESPEED_API_KEY=""

# CRUX_API_KEY: Server-side Chrome UX Report API key (https://developer.chrome.com/docs/crux/api).
# Powers /api/scan/crux (real-user Core Web Vitals + history). Kept on the server,
# not exposed to the browser. Without it the live card uses the PageSpeed lab fallback.
CRUX_API_KEY=""
